model Resume {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Chat {
  id             String        @id @default(cuid())
  userId         String? // Optional: Can be "whatsapp:+123..." or null for web
  organizationId String? // Which organization this chat belongs to (for WhatsApp business)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  virtualSelfId  String? // ID of the user whose virtual self is being chatted with
  virtualSelf    User?         @relation("VirtualSelfChats", fields: [virtualSelfId], references: [id], onDelete: Cascade)
  isSharedChat   Boolean       @default(false) // True if this is a shared virtual self chat
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  messages       Message[]

  @@index([virtualSelfId])
  @@index([organizationId])
  @@index([userId, organizationId])
}

model Message {
  id         String   @id @default(cuid())
  chatId     String
  role       String // "user" or "assistant"
  content    String   @db.Text
  tokenCount Int? // AI tokens used for this message exchange
  createdAt  DateTime @default(now())
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

model Feedback {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  virtualSelfSlug String?
  rating          Int
  comment         String?  @db.Text
  createdAt       DateTime @default(now())
}

model KnowledgeBase {
  id             String        @id @default(cuid())
  userId         String?       @unique
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?       @unique
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Identity
  fullName           String?
  birthDate          String?
  birthPlace         String?
  currentLocation    String?
  languages          String? // Comma-separated or JSON
  bio                String? @db.Text
  relationshipStatus String?
  hobbies            String? // Comma-separated or JSON
  favoriteFood       String?

  // Education (JSON or Text)
  education String? @db.Text

  // Experience (JSON or Text)
  experience String? @db.Text

  // Skills (JSON or Text)
  skills String? @db.Text

  // Projects (JSON or Text)
  projects String? @db.Text

  // Awards (JSON or Text)
  awards String? @db.Text

  // Social Links (JSON or Text)
  socialLinks String? @db.Text

  // Social Updates
  socialUpdates String? @db.Text

  // Q&A pairs for digital twin (JSON array)
  qaPairs Json?

  // Full raw content (optional backup)
  rawContent String? @db.Text

  // Training status
  isModelTrained Boolean   @default(false)
  trainedPrompt  String?   @db.Text
  lastTrainedAt  DateTime?

  // Sharing
  shareSlug        String? @unique // Unique slug for sharing (e.g., "tresor", "john-doe")
  isPubliclyShared Boolean @default(false)
  shareViews       Int     @default(0) // Track how many times shared link was accessed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Organization Model for WhatsApp Business Numbers
model Organization {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text

  // Owner
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // WhatsApp Configuration
  whatsappNumber    String? @unique // E.g., "+250788111111"
  whatsappNumberSid String? // Twilio Phone Number SID (for management)
  displayName       String? // Business display name on WhatsApp

  // AI Configuration
  knowledgeBaseId String?        @unique
  knowledgeBase   KnowledgeBase?

  // Status & Plan
  isActive Boolean @default(true)
  planType String  @default("trial") // "trial", "starter", "business", "enterprise"

  // Limits & Usage (based on plan)
  monthlyMessageLimit Int       @default(100) // Messages per month
  monthlyMessageCount Int       @default(0) // Current month usage
  monthlyTokenLimit   Int       @default(200000) // Token budget per month
  monthlyTokenCount   Int       @default(0) // Tokens consumed this month
  tokensExhaustedAt   DateTime? // Set when tokens first hit 0; cleared on payment or reset
  lastResetDate       DateTime  @default(now()) // When counter was last reset

  // Agent configuration
  agentName        String?
  agentPersonality String? @db.Text

  // API access key for external integrations
  apiKey     String? @unique
  apiKeyHash String? @unique // SHA-256 of apiKey — use this for secure lookups after migration

  // Business Info
  industry     String?
  website      String?
  contactEmail String?

  // Settings
  businessHoursEnabled Boolean @default(false)
  businessHoursStart   String? // E.g., "09:00"
  businessHoursEnd     String? // E.g., "17:00"
  timezone             String? // E.g., "Africa/Kigali"
  autoReplyEnabled     Boolean @default(true)
  welcomeMessage       String? @db.Text

  // Analytics
  totalConversations  Int    @default(0)
  totalMessages       Int    @default(0)
  averageResponseTime Float? // In seconds

  // Billing
  planRenewalDate DateTime?
  billingEmail    String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  chats          Chat[]
  billingRecords BillingRecord[]
  notifications  Notification[]
  dataAnalyses   DataAnalysis[]

  @@index([ownerId])
  @@index([whatsappNumber])
}

model BillingRecord {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan           String // "starter" | "pro" | "scale"
  amountRWF      Int // Amount in RWF
  periodMonths   Int          @default(1) // 1 = monthly, 6 = semi-annual, 12 = yearly
  txRef          String       @unique // Flutterwave transaction reference
  flwRef         String? // Flutterwave internal reference (after verify)
  status         String       @default("pending") // "pending" | "success" | "failed"
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([txRef])
}

model DataAnalysis {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fileName    String
  rowCount    Int          @default(0)
  columnNames Json         @default("[]")
  summary     String       @db.Text
  insights    Json         @default("[]")
  charts      Json         @default("[]")
  decisions   Json         @default("[]")
  chatHistory Json         @default("[]")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([orgId])
  @@map("data_analyses")
}

// NextAuth Models

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String?   @unique
  emailVerified      DateTime?
  image              String?
  accountType        String    @default("personal") // "personal" or "organization"
  onboardingComplete Boolean   @default(false) // Track if user completed onboarding
  status             String    @default("active") // "active" | "pending" | "banned" | "flagged"
  role               String    @default("user") // "user" | "admin"
  passwordHash       String? // Only set for admin credential accounts
  createdAt          DateTime  @default(now())

  // Personal billing
  personalPlanType          String    @default("free") // "free" | "plus"
  personalMonthlyMsgCount   Int       @default(0)
  personalMonthlyMsgLimit   Int       @default(200)
  personalMonthlyTokenCount Int       @default(0) // Tokens consumed this month
  personalMonthlyTokenLimit Int       @default(400000) // Token budget per month
  personalPlanRenewalDate   DateTime?
  creditsExhaustedAt        DateTime? // Set when credits first hit 0; cleared on payment or monthly reset

  accounts           Account[]
  sessions           Session[]
  knowledgeBase      KnowledgeBase?
  virtualSelfChats   Chat[]              @relation("VirtualSelfChats")
  organizations      Organization[] // Organizations owned by this user
  swag               Swag[] // Swag items created by this user
  generatedResumes   GeneratedResume[]
  userBillingRecords UserBillingRecord[]
  notifications      Notification[]
  moderationReports  ModerationReport[]
  feedbacks          Feedback[]
  verifyTokens       VerifyToken[]
}

model UserBillingRecord {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         String // "plus"
  amountRWF    Int
  periodMonths Int      @default(1) // 1 = monthly, 6 = semi-annual, 12 = yearly
  txRef        String   @unique
  flwRef       String?
  status       String   @default("pending") // "pending" | "success" | "failed"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([txRef])
}

model Swag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text // Swag content (JSON or text)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VerifyToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  token     String   @unique
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId, createdAt])
}

model ModerationReport {
  id           String    @id @default(cuid())
  type         String // "message" | "profile" | "content" | "feedback"
  severity     String    @default("medium") // "high" | "medium" | "low"
  status       String    @default("pending") // "pending" | "resolved" | "dismissed"
  reason       String
  excerpt      String?   @db.Text
  reporter     String? // Reporter name/email or "System"
  target       String? // Description of the reported entity
  targetUserId String?
  targetUser   User?     @relation(fields: [targetUserId], references: [id], onDelete: SetNull)
  resolvedBy   String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([targetUserId])
}

model PlatformSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model GeneratedResume {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  html      String   @db.Text
  style     String   @default("modern")
  tone      String   @default("Professional")
  jobTitle  String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// Admin-sent notifications to users and/or organizations
model Notification {
  id             String        @id @default(cuid())
  // Targeting: null = broadcast to all personal users; string = specific userId
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Targeting: null = not org-specific; string = specific orgId
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // "system" | "billing" | "info" | "warning"
  type      String   @default("info")
  // "personal" | "org" | "all" — describes the broadcast scope used at send time
  scope     String   @default("all")
  title     String
  body      String   @db.Text
  // Whether this was read by the recipient (for 1-1 notifications)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([scope])
}
